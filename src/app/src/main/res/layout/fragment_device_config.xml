<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_device_config"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/device_name"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_device_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/device_name_hint"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:background="@color/surface"
            android:textColorHint="@color/text_hint"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/device_description"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_device_describe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/device_description_hint"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:background="@color/surface"
            android:textColorHint="@color/text_hint"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/backup_path"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/backup_path_description"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_backup_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/backup_path_hint"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:background="@color/surface"
            android:textColorHint="@color/text_hint"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/max_backup_count"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/max_backup_count_description"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_backup_max"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="5"
            android:inputType="number"
            android:textColor="@color/text_primary"
            android:background="@color/surface"
            android:textColorHint="@color/text_hint"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <Switch
            android:id="@+id/sw_log_enabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/write_error_log"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/log_path_hint"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_config"
            android:backgroundTint="@color/primary" />

        <TextView
            android:id="@+id/tv_footer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/footer_text"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:textColorLink="@color/primary"
            android:autoLink="web"
            android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>
