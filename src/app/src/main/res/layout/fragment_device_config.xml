<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设备配置"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设备名称"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_device_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="例: 远程备份设备"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:background="@color/surface"
            android:textColorHint="@color/text_hint"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设备描述"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_device_describe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="例: 我的云端备份设备"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:background="@color/surface"
            android:textColorHint="@color/text_hint"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="上传线程数"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_upload_threads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="3"
            android:inputType="number"
            android:textColor="@color/text_primary"
            android:background="@color/surface"
            android:textColorHint="@color/text_hint"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="备份路径"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="在云端存储的起始路径"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_backup_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="例: MIUI/backup"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:background="@color/surface"
            android:textColorHint="@color/text_hint"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="最大备份数"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="超出数量时自动清理旧备份，设 0 不清理"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_backup_max"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="5"
            android:inputType="number"
            android:textColor="@color/text_primary"
            android:background="@color/surface"
            android:textColorHint="@color/text_hint"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="保存配置"
            android:backgroundTint="@color/primary" />

        <TextView
            android:id="@+id/tv_footer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/footer_text"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:textColorLink="@color/primary"
            android:autoLink="web"
            android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>
